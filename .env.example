# AegisFlow local development configuration.
# Copy to .env.local for local use. Keep real secrets out of git.

APP_NAME="AegisFlow API"
APP_VERSION=0.1.0
SERVICE_NAME=aegis-flow-api
ENVIRONMENT=local

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_NAME=aegis_flow
DB_USERNAME=postgres
DB_PASSWORD=change-me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=change-me
REDIS_DATABASE=0

# S3 / MinIO
S3_ENABLED=true
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_BUCKET=aegis-flow
S3_ACCESS_KEY=change-me
S3_SECRET_KEY=change-me

# Milvus
MILVUS_URI=http://localhost:19530
MILVUS_USERNAME=root
MILVUS_PASSWORD=change-me

# Security
SECURITY_ACCESS_TOKEN_EXPIRE_MINUTES=60
